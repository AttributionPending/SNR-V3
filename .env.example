# ── LLM Provider ──────────────────────────────────────────────────────────────
# Default provider: Anthropic (Claude)
# WARNING: Never commit real API keys. Use a .env file that is in .gitignore.
ANTHROPIC_API_KEY=sk-XXXXXXXXXXXXXXXXXXXX
# Container/hardened hosts: point at a mounted secret file instead of the value.
# Any secret below also supports a *_FILE variant (file contents take precedence).
# ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic_api_key

# Optional: override the default Claude model
# CLAUDE_MODEL=claude-sonnet-4-5

# To use an OpenAI-compatible endpoint (Ollama, LM Studio, vLLM, etc.),
# configure these in the Settings UI > LLM Provider, or set them here:
# LLM_PROVIDER=openai-compatible
# API_BASE_URL=http://localhost:11434/v1
# API_KEY=ollama
# MODEL_NAME=llama3.2

# ── Analyst Identity ─────────────────────────────────────────────────────────
ANALYST_NAME=CTI Analyst
ANALYST_EMAIL=cti-analyst@organization.com
ANALYST_ORG=Security Operations

# ── Server Configuration ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Bind address. Defaults: 127.0.0.1 in dev, 0.0.0.0 in production/containers.
# HOST=0.0.0.0

# Number of reverse-proxy hops to trust (for real client IP + rate limiting).
# Defaults: off in dev, 1 in production. Set to your proxy depth if different.
# TRUST_PROXY=1

# Database path (use an absolute path on a persistent volume in production)
DB_PATH=./snr.db

# CORS allowed origins (comma-separated, REQUIRED in production)
# ALLOWED_ORIGINS=https://snr.yourorg.com

# ── Authentication ───────────────────────────────────────────────────────────
# First-run admin bootstrap (required on first start)
# Password must be 10+ chars with uppercase, lowercase, number, and special char.
A2N_ADMIN_EMAIL=admin@yourorg.com
A2N_ADMIN_PASSWORD=CHANGE_ME_Secure1!
# A2N_ADMIN_PASSWORD_FILE=/run/secrets/admin_password

# JWT secret. REQUIRED in production (the server refuses to start without it).
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_SECRET=your_random_64_byte_hex_string
# JWT_SECRET_FILE=/run/secrets/jwt_secret

# ── Backups ──────────────────────────────────────────────────────────────────
# Scheduled consistent DB snapshots. Interval 0 disables. Retention = newest N kept.
# Defaults: every 24h, keep 7, written to <DB dir>/backups.
# BACKUP_INTERVAL_HOURS=24
# BACKUP_RETENTION=7
# BACKUP_DIR=/data/backups

# ── Observability ────────────────────────────────────────────────────────────
# LOG_LEVEL=info                # trace|debug|info|warn|error|fatal
# METRICS_TOKEN=                # if set, GET /metrics requires: Authorization: Bearer <token>

# ── Deployment (docker-compose) ──────────────────────────────────────────────
# Domain for the Caddy TLS reverse proxy (use "localhost" for a self-signed cert).
# SNR_DOMAIN=snr.yourorg.com
